{
	"$schema": "https://biomejs.dev/schemas/2.3.5/schema.json",
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"noNonNullAssertion": "off",
				"useConst": "error",
				"useNodejsImportProtocol": "off"
			},
			"suspicious": {
				"noExplicitAny": "off",
				"noControlCharactersInRegex": "off",
				"noEmptyInterface": "off"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"formatWithErrors": false,
		"indentStyle": "tab",
		"indentWidth": 3,
		"lineWidth": 120
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"overrides": [
		{
			"includes": ["packages/desktop/**"],
			"formatter": {
				"indentStyle": "space",
				"indentWidth": 2
			}
		},
		{
			"includes": ["packages/desktop/**/*.tsx", "packages/desktop/**/*.css"],
			"linter": {
				"enabled": false
			}
		}
	],
	"files": {
		"includes": [
			"packages/*/src/**/*.ts",
			"packages/*/test/**/*.ts",
			"packages/desktop/*.ts",
			"packages/desktop/**/*.tsx",
			"packages/desktop/**/*.css",
			"packages/desktop/**/*.json",
			"packages/coding-agent/examples/**/*.ts",
			"!packages/desktop/out/**/*",
			"!**/node_modules/**/*",
			"!**/test-sessions.ts",
			"!**/models.generated.ts",
			"!**/*.models.ts",
			"!packages/mom/data/**/*",
			"!!**/node_modules"
		]
	}
}
