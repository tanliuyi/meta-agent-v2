{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"composite": true,
		"target": "ES2024",
		"jsx": "react-jsx",
		"lib": ["ES2024", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"noEmit": true,
		"types": ["vite/client"]
	},
	"include": ["src/renderer/src/**/*.ts", "src/renderer/src/**/*.tsx", "src/shared/**/*.ts"]
}
