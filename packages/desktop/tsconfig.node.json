{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"composite": false,
		"target": "ES2024",
		"lib": ["ES2024", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"noEmit": true,
		"types": ["node", "electron-vite/node"],
		"paths": {
			"@earendil-works/pi-coding-agent": ["./src/main/pi/pi-sdk.d.ts"]
