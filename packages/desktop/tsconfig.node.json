{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "target": "ES2024",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@earendil-works/pi-coding-agent/models-config": ["../coding-agent/src/core/models-config.ts"]
    },
    "noEmit": true,
    "types": ["node", "electron-vite/node"]
  },
  "include": ["electron.vite.config.ts", "src/main/**/*.ts", "src/preload/**/*.ts", "src/shared/**/*.ts"],
  "exclude": [
    "src/main/pi/host-ui.ts",
    "src/main/pi/pi-compatibility-adapter.ts",
    "src/main/pi/pi-thread-projector.ts",
    "src/main/pi/session-commands.ts",
    "src/main/pi/session-configuration.ts",
    "src/main/pi/session-runtime.ts"
  ]
}
