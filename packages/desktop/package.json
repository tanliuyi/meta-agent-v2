{
  "name": "@earendil-works/pi-desktop",
  "version": "0.0.26",
  "private": true,
  "description": "Meta Agent desktop application",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "prepare:node-pty": "node ../../scripts/prepare-desktop-node-pty.mjs",
    "generate-routes": "tsr generate",
    "predev": "npm run prepare:node-pty && npm run generate-routes",
    "build:pi": "npm --prefix ../tui run build && tsgo -p ../ai/tsconfig.build.json && npm --prefix ../agent run build && npm --prefix ../coding-agent run build && npm run build:sidecar",
    "build:sidecar": "node ../../scripts/clean-desktop-sidecar-output.mjs && tsgo -p tsconfig.sidecar.json && node ../../scripts/generate-desktop-sidecar-manifest.mjs",
    "dev": "npm run build:pi && electron-vite dev",
    "prepreview": "npm run prepare:node-pty && npm run generate-routes",
    "preview": "npm run build:pi && electron-vite preview",
    "pretypecheck": "npm run generate-routes",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.sidecar.json && tsc --noEmit -p tsconfig.web.json",
    "prebuild": "npm run prepare:node-pty",
    "build": "npm run build:pi && npm run typecheck && electron-vite build && node ../../scripts/verify-desktop-main-boundary.mjs",
    "package": "npm run build && electron-builder --config electron-builder.yml",
    "build:win": "npm run build && electron-builder --config electron-builder.yml --win",
    "smoke:sidecar": "node ../../scripts/smoke-desktop-sidecar.mjs",
    "smoke:gui": "node ../../scripts/smoke-desktop-gui.mjs"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.80.7",
    "electron-devtools-installer": "4.0.0",
    "electron-window-state": "5.0.3",
    "jsonc-parser": "3.3.1",
    "node-pty": "1.1.0",
    "proper-lockfile": "4.1.2"
  },
  "devDependencies": {
    "@assistant-ui/react": "0.14.26",
    "@assistant-ui/react-devtools": "1.2.8",
    "@assistant-ui/react-streamdown": "0.3.5",
    "@earendil-works/pi-ai": "0.80.7",
    "@radix-ui/react-alert-dialog": "1.1.19",
    "@radix-ui/react-avatar": "1.2.2",
    "@radix-ui/react-checkbox": "1.3.7",
    "@radix-ui/react-collapsible": "1.1.16",
    "@radix-ui/react-context-menu": "2.3.3",
    "@radix-ui/react-dialog": "1.1.19",
    "@radix-ui/react-popover": "1.1.19",
    "@radix-ui/react-radio-group": "1.4.3",
    "@radix-ui/react-scroll-area": "1.2.14",
    "@radix-ui/react-select": "2.3.3",
    "@radix-ui/react-slot": "1.3.0",
    "@radix-ui/react-tabs": "1.1.17",
    "@radix-ui/react-tooltip": "1.2.12",
    "@streamdown/cjk": "1.0.3",
    "@streamdown/code": "1.1.1",
    "@streamdown/math": "1.0.2",
    "@streamdown/mermaid": "1.0.2",
    "@tailwindcss/vite": "4.3.2",
    "@tanstack/react-router": "1.170.18",
    "@tanstack/router-cli": "1.167.21",
    "@tanstack/router-plugin": "1.168.23",
    "@types/node": "24.12.4",
    "@types/proper-lockfile": "4.1.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "katex": "0.16.27",
    "lucide-react": "1.24.0",
    "playwright": "1.61.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "streamdown": "2.5.0",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.2",
    "tw-animate-css": "1.4.0",
    "tw-shimmer": "0.4.11",
    "typescript": "5.9.3",
    "vite": "7.3.6",
    "vitest": "4.1.9",
    "zustand": "5.0.14"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
